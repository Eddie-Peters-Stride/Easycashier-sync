{
  "name": "easycashier-sync",
  "version": "0.1.0",
  "description": "Internal package for Gadget app easycashier-sync (Development environment)",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "build": "NODE_ENV=production react-router build",
    "test": "node --experimental-default-type=module --test --test-concurrency=1 tests/unit/manageProduct.test.js tests/unit/easycashierRateLimit.test.js tests/integration/easycashierInventoryLocationSync.test.js tests/integration/easycashierProductSync.test.js tests/integration/syncAllProductsToEasyCashier.test.js",
    "test:integration": "node --experimental-default-type=module --test --test-concurrency=1 tests/integration/easycashierInventoryLocationSync.test.js tests/integration/easycashierProductSync.test.js tests/integration/syncAllProductsToEasyCashier.test.js",
    "test:unit": "node --experimental-default-type=module --test --test-concurrency=1 tests/unit/manageProduct.test.js tests/unit/easycashierRateLimit.test.js",
    "shopify": "shopify",
    "shopify:config:use:development": "shopify app config use shopify.app.development.toml",
    "shopify:config:use:production": "shopify app config use shopify.app.toml",
    "shopify:dev": "yarn shopify:deploy:development --force && yarn shopify:config:use:development && shopify app dev --no-update",
    "shopify:deploy:development": "yarn shopify:config:use:development && shopify app deploy",
    "shopify:deploy:production": "yarn shopify:config:use:production && shopify app deploy",
    "shopify:deploy": "yarn shopify:deploy:production",
    "shopify:info": "shopify app info"
  },
  "dependencies": {
    "@gadget-client/easycashier-sync": "link:.gadget/client",
    "@gadgetinc/react": "^0.25.1",
    "@gadgetinc/react-shopify-app-bridge": "^0.21.4",
    "@react-router/fs-routes": "^7.12.0",
    "@react-router/node": "^7.12.0",
    "@react-router/serve": "^7.12.0",
    "@shopify/polaris-icons": "^9.3.0",
    "gadget-server": "link:.gadget/server",
    "isbot": "^5.1.0",
    "react": "^19.1.2",
    "react-dom": "^19.1.2",
    "react-router": "^7.12.0",
    "shopify-api-node": "^3.15.0"
  },
  "devDependencies": {
    "@react-router/dev": "^7.12.0",
    "@shopify/polaris-types": "1.0.1",
    "@types/node": "^25.6.2",
    "@types/react": "^19.1.1",
    "@types/react-dom": "^19.1.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.4"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
